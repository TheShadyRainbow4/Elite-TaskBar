+// Subclass procedure for routing tray items mouse clicks and interactions in independent mode
+LRESULT CALLBACK TrayToolbarSubclassProc(HWND hWnd, UINT uMsg, WPARAM wParam, LPARAM lParam, UINT_PTR uIdSubclass, DWORD_PTR dwRefData) {
+    switch (uMsg) {
+    case WM_LBUTTONDOWN:
+    case WM_LBUTTONUP:
+    case WM_RBUTTONDOWN:
+    case WM_RBUTTONUP:
+    case WM_MBUTTONDOWN:
+    case WM_MBUTTONUP:
+    case WM_LBUTTONDBLCLK:
+    case WM_RBUTTONDBLCLK:
+    case WM_MBUTTONDBLCLK:
+    case WM_MOUSEMOVE: {
+        POINT pt;
+        pt.x = GET_X_LPARAM(lParam);
+        pt.y = GET_Y_LPARAM(lParam);
+        
+        int btnIndex = (int)SendMessageW(hWnd, TB_HITTEST, 0, (LPARAM)&pt);
+        if (btnIndex >= 0 && btnIndex < (int)g_CurrentTrayIcons.size()) {
+            const auto& icon = g_CurrentTrayIcons[btnIndex];
+            PostMessageW(icon.hwnd, icon.uCallbackMessage, icon.uID, uMsg);
+        }
+        break;
+    }
+    }
+    return DefSubclassProc(hWnd, uMsg, wParam, lParam);
+}
+
+// Subclass procedure for showing tray tooltips on hover in independent mode
+LRESULT CALLBACK TraySysPagerSubclassProc(HWND hWnd, UINT uMsg, WPARAM wParam, LPARAM lParam, UINT_PTR uIdSubclass, DWORD_PTR dwRefData) {
+    if (uMsg == WM_NOTIFY) {
+        LPNMHDR nmhdr = (LPNMHDR)lParam;
+        if (nmhdr->code == TTN_GETDISPINFOW) {
+            LPNMTTDISPINFOW pDispInfo = (LPNMTTDISPINFOW)lParam;
+            int btnIndex = (int)pDispInfo->hdr.idFrom;
+            if (btnIndex >= 0 && btnIndex < (int)g_CurrentTrayIcons.size()) {
+                pDispInfo->lpszText = g_CurrentTrayIcons[btnIndex].szTip;
+                pDispInfo->hinst = NULL;
+                return 0;
+            }
+        }
+    }
+    return DefSubclassProc(hWnd, uMsg, wParam, lParam);
+}
+
+// Layout coordinator to adjust tray size dynamically
+void UpdateTrayLayout(HWND hTrayNotify) {
+    TaskbarInstance* inst = GetTaskbarInstance(hTrayNotify);
+    if (!inst || !inst->hToolbar) return;
+    
+    int btnCount = SendMessageW(inst->hToolbar, TB_BUTTONCOUNT, 0, 0);
+    int W_tray = 48; // minimum fallback
+    if (btnCount > 0) {
+        RECT rc = {0};
+        if (SendMessageW(inst->hToolbar, TB_GETITEMRECT, btnCount - 1, (LPARAM)&rc)) {
+            W_tray = rc.right + 4;
+        }
+    }
+    
+    int W_clock = inst->hTrayClock ? MulDiv(140, inst->dpi, 96) : 0;
+    int totalWidth = W_tray + W_clock;
+    
+    // Reposition pager and toolbar
+    SetWindowPos(inst->hSysPager, NULL, 0, 0, W_tray, inst->taskbarHeight, SWP_NOZORDER | SWP_NOACTIVATE);
+    SetWindowPos(inst->hToolbar, NULL, 0, 0, W_tray, inst->taskbarHeight, SWP_NOZORDER | SWP_NOACTIVATE);
+    
+    // Reposition clock
+    if (inst->hTrayClock) {
+        SetWindowPos(inst->hTrayClock, NULL, W_tray, 0, W_clock, inst->taskbarHeight, SWP_NOZORDER | SWP_NOACTIVATE);
+    }
+    
+    // Reposition TrayNotifyWnd
+    RECT rcTask;
+    GetClientRect(inst->hTaskbar, &rcTask);
+    int screenWidth = rcTask.right - rcTask.left;
+    SetWindowPos(inst->hTrayNotify, NULL, screenWidth - totalWidth - 15, 0, totalWidth, inst->taskbarHeight, SWP_NOZORDER | SWP_NOACTIVATE);
+    
+    // Resize TaskSwitch (Taskband)
+    if (inst->hTaskSwitch) {
+        int startBtnWidth = 60;
+        int remainingWidth = screenWidth - startBtnWidth - totalWidth - 15;
+        SetWindowPos(inst->hTaskSwitch, NULL, startBtnWidth, 0, remainingWidth, inst->taskbarHeight, SWP_NOZORDER | SWP_NOACTIVATE);
+    }
+}
