+// UWP and Win32 Unified Icon Extraction Helper
+HICON ExtractWindowIcon(HWND hwnd) {
+    DWORD_PTR dwRes = 0;
+    HICON hIcon = NULL;
+    
+    // Check for UWP frame window class
+    WCHAR szClass[256] = {0};
+    GetClassNameW(hwnd, szClass, 256);
+    if (wcscmp(szClass, L"ApplicationFrameWindow") == 0) {
+        // Try Property Store and COM Shell Item extraction
+        IPropertyStore* pPropStore = nullptr;
+        HRESULT hr = SHGetPropertyStoreForWindow(hwnd, IID_PPV_ARGS(&pPropStore));
+        if (SUCCEEDED(hr)) {
+            PROPVARIANT var;
+            PropVariantInit(&var);
+            hr = pPropStore->GetValue(PKEY_AppUserModel_ID, &var);
+            if (SUCCEEDED(hr) && var.vt == VT_LPWSTR) {
+                std::wstring path = L"shell:AppsFolder\\" + std::wstring(var.pwszVal);
+                IShellItem* pShellItem = nullptr;
+                hr = SHCreateItemFromParsingName(path.c_str(), nullptr, IID_PPV_ARGS(&pShellItem));
+                if (SUCCEEDED(hr)) {
+                    IShellItemImageFactory* pImageFactory = nullptr;
+                    hr = pShellItem->QueryInterface(IID_PPV_ARGS(&pImageFactory));
+                    if (SUCCEEDED(hr)) {
+                        HBITMAP hBitmap = nullptr;
+                        SIZE size = {16, 16};
+                        hr = pImageFactory->GetImage(size, SIIGBF_BIGNORMAL | SIIGBF_ICONONLY, &hBitmap);
+                        if (SUCCEEDED(hr)) {
+                            ICONINFO ii = {0};
+                            ii.fIcon = TRUE;
+                            HBITMAP hMask = CreateBitmap(16, 16, 1, 1, nullptr);
+                            ii.hbmMask = hMask;
+                            ii.hbmColor = hBitmap;
+                            hIcon = CreateIconIndirect(&ii);
+                            DeleteObject(hMask);
+                            DeleteObject(hBitmap);
+                        }
+                        pImageFactory->Release();
+                    }
+                    pShellItem->Release();
+                }
+            }
+            PropVariantClear(&var);
+            pPropStore->Release();
+        }
+        
+        // Fallback: search child CoreWindow for executable path and extract icon
+        if (!hIcon) {
+            HWND hChild = FindWindowExW(hwnd, nullptr, L"Windows.UI.Core.CoreWindow", nullptr);
+            if (hChild) {
+                DWORD childPid = 0;
+                GetWindowThreadProcessId(hChild, &childPid);
+                HANDLE hProcess = OpenProcess(PROCESS_QUERY_LIMITED_INFORMATION, FALSE, childPid);
+                if (hProcess) {
+                    WCHAR szPath[MAX_PATH] = {0};
+                    DWORD dwSize = MAX_PATH;
+                    if (QueryFullProcessImageNameW(hProcess, 0, szPath, &dwSize)) {
+                        SHFILEINFOW sfi = {0};
+                        if (SHGetFileInfoW(szPath, 0, &sfi, sizeof(sfi), SHGFI_ICON | SHGFI_SMALLICON)) {
+                            hIcon = sfi.hIcon;
+                        }
+                    }
+                    CloseHandle(hProcess);
+                }
+            }
+        }
+    }
+    
+    if (!hIcon) {
+        if (SendMessageTimeoutW(hwnd, WM_GETICON, ICON_SMALL, 0, SMTO_ABORTIFHUNG, 500, &dwRes)) {
+            hIcon = (HICON)dwRes;
+        }
+        if (!hIcon) {
+            hIcon = (HICON)GetClassLongPtrW(hwnd, GCLP_HICONSM);
+        }
+    }
+    return hIcon;
+}
 
