    PUSHBUTTON      "Desktop Color", IDC_ADV_COLOR_DESKTOP, 14, 40, 100, 14
    PUSHBUTTON      "Active Titlebar Color", IDC_ADV_COLOR_ACTIVETITLE, 14, 60, 100, 14
    PUSHBUTTON      "Titlebar Gradient", IDC_ADV_COLOR_GRADIENT, 14, 80, 100, 14
    PUSHBUTTON      "Window Text Color", IDC_ADV_COLOR_TEXT, 14, 100, 100, 14
    PUSHBUTTON      "Caption Text Color", IDC_ADV_COLOR_CAPTIONTEXT, 14, 120, 100, 14
    PUSHBUTTON      "Font Style & Size", IDC_ADV_FONT, 14, 140, 100, 14
