IDB_START_ORB_AQUABOTTOM RCDATA "..\\Resources\\StartOrb\\aqua bottom.png"
IDB_START_ORB_DUNES RCDATA "..\\Resources\\StartOrb\\dunes.png"
IDB_START_ORB_INDIGO RCDATA "..\\Resources\\StartOrb\\indigo.png"
IDB_START_ORB_SAPPHIRE RCDATA "..\\Resources\\StartOrb\\sapphire.png"
