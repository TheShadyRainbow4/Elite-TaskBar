IDB_START_ORB_VIENNABOTTOM RCDATA "..\\Resources\\StartOrb\\vienna bottom.png"

IDD_TASKBAR_PROPS DIALOGEX 0, 0, 252, 275
STYLE DS_SETFONT | WS_CHILD | WS_DISABLED | WS_CAPTION | DS_CONTROL
CAPTION "Taskbar"
FONT 8, "Segoe UI Semibold", 600, 0, 0x1
BEGIN
    GROUPBOX        "Taskbar Mode", IDC_STATIC, 7, 7, 238, 45
    CONTROL         "Independent", IDC_MODE_INDEPENDENT, "Button", BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP, 14, 20, 60, 10
    CONTROL         "Replace", IDC_MODE_REPLACE, "Button", BS_AUTORADIOBUTTON, 80, 20, 50, 10
    CONTROL         "Secondary Only", IDC_MODE_SECONDARY_ONLY, "Button", BS_AUTORADIOBUTTON, 140, 20, 70, 10
    
    GROUPBOX        "Taskbar Appearance", IDC_STATIC, 7, 58, 238, 122
    LTEXT           "Button Width:", IDC_STATIC, 14, 73, 50, 8
    CONTROL         "Auto", IDC_WIDTH_AUTO, "Button", BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP, 65, 72, 35, 10
    CONTROL         "Fixed", IDC_WIDTH_FIXED, "Button", BS_AUTORADIOBUTTON, 105, 72, 35, 10
    CONTROL         "Icons Only", IDC_WIDTH_ICONS, "Button", BS_AUTORADIOBUTTON, 145, 72, 45, 10
    LTEXT           "Fixed Size:", IDC_WIDTH_FIXED_SIZE_LBL, 65, 87, 40, 8
    COMBOBOX        IDC_WIDTH_FIXED_SIZE, 105, 85, 80, 150, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    CONTROL         "Show window previews", IDC_HOVER_PREVIEW, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 103, 114, 10
    CONTROL         "Enable Portable Mirror Mode", IDC_PORTABLE_MIRROR, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 118, 200, 10
    CONTROL         "Enable Two-Row Notification Tray", IDC_TWO_ROW_TRAY, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 133, 200, 10
    CONTROL         "Dynamic Clock Width", IDC_DYNAMIC_CLOCK_WIDTH, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 148, 200, 10
    CONTROL         "Horizontal Tray Chevron", IDC_HORIZONTAL_TRAY_CHEVRON, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 163, 200, 10

    GROUPBOX        "Custom Icon Theme Folder", IDC_STATIC, 7, 185, 238, 85
    LTEXT           "Theme Path:", IDC_STATIC, 14, 200, 45, 8
    EDITTEXT        IDC_THEME_FOLDER_PATH, 65, 198, 120, 12, ES_AUTOHSCROLL | WS_TABSTOP
    PUSHBUTTON      "Browse...", IDC_THEME_FOLDER_BROWSE, 190, 197, 50, 14, WS_TABSTOP
    CONTROL         "Enable Dark Mode", IDC_ENABLE_DARK_MODE, "Button", BS_AUTOCHECKBOX | WS_DISABLED | WS_TABSTOP, 14, 217, 150, 10
    LTEXT           "Manual Tray Width:", IDC_STATIC, 14, 234, 65, 8
    EDITTEXT        IDC_MANUAL_TRAY_WIDTH, 85, 232, 40, 12, ES_NUMBER | WS_TABSTOP
    LTEXT           "px (0 = Auto)", IDC_STATIC, 130, 234, 50, 8
END

IDD_NATIVE_PROPS DIALOGEX 0, 0, 252, 218
STYLE DS_SETFONT | WS_CHILD | WS_DISABLED | WS_CAPTION | DS_CONTROL
CAPTION "Native Settings"
FONT 8, "Segoe UI Semibold", 600, 0, 0x1
BEGIN
    GROUPBOX        "Native Integration", IDC_STATIC, 7, 7, 238, 75
    CONTROL         "Write settings to native registry (Sync with explorer)", IDC_NATIVE_REGISTRY_MODE, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 18, 220, 10
    CONTROL         "Use fully native TaskBand (Requires theme support)", IDC_USE_NATIVE_TASKBAND, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 30, 220, 10
    CONTROL         "Native Win7 Tray", IDC_TRAY_NATIVE, "Button", BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP, 14, 44, 100, 10
    CONTROL         "Legacy Tray", IDC_TRAY_LEGACY, "Button", BS_AUTORADIOBUTTON, 120, 44, 100, 10
    CONTROL         "Run EliteTaskbar as primary Windows shell replacement", IDC_PRIMARY_SHELL_MODE, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 58, 220, 12
    
    GROUPBOX        "Shell Taskbar Overrides", IDC_STATIC, 7, 86, 238, 51
    CONTROL         "Lock the taskbar", IDC_LOCK_TASKBAR, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 96, 220, 10
    CONTROL         "Auto-hide the taskbar", IDC_AUTOHIDE_TASKBAR, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 108, 220, 10
    CONTROL         "Use small icons", IDC_SMALL_ICONS, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 120, 100, 10

    GROUPBOX        "Explorer Replacement", IDC_STATIC, 7, 141, 238, 32
    CONTROL         "None", IDC_REPLACE_EXPLORER_NONE, "Button", BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP, 14, 150, 50, 10
    CONTROL         "FileSystem Only", IDC_REPLACE_EXPLORER_FILESYS, "Button", BS_AUTORADIOBUTTON, 80, 150, 70, 10
    CONTROL         "All Folders", IDC_REPLACE_EXPLORER_ALL, "Button", BS_AUTORADIOBUTTON, 160, 150, 60, 10
    
    GROUPBOX        "Configuration Backup", IDC_STATIC, 7, 177, 238, 34
    PUSHBUTTON      "Import Settings...", IDC_IMPORT_SETTINGS, 14, 189, 100, 14
    PUSHBUTTON      "Export Settings...", IDC_EXPORT_SETTINGS, 120, 189, 100, 14
END

IDD_MULTIMON_PROPS DIALOGEX 0, 0, 252, 218
STYLE DS_SETFONT | WS_CHILD | WS_DISABLED | WS_CAPTION | DS_CONTROL
CAPTION "Multi-Monitor"
FONT 8, "Segoe UI Semibold", 600, 0, 0x1
BEGIN
