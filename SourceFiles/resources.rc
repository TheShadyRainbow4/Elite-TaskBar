#include <windows.h>
#include "resource.h"

IDI_MAIN_PROGRAM ICON "..\\Resources\\MAIN_PROGRAM.ico"
IDI_PREFERENCES ICON "..\\Resources\\PREFERENCES.ico"
IDB_START_ORB RCDATA "..\\Resources\\StartOrb\\orb.png"

IDD_TASKBAR_PROPS DIALOGEX 0, 0, 252, 218
STYLE DS_SETFONT | DS_FIXEDSYS | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Taskbar"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    GROUPBOX        "Taskbar Appearance", IDC_STATIC, 7, 7, 238, 70
    CONTROL         "Lock the taskbar", IDC_LOCK_TASKBAR, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 20, 220, 10
    CONTROL         "Auto-hide the taskbar", IDC_AUTOHIDE_TASKBAR, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 34, 220, 10
    CONTROL         "Use small icons", IDC_SMALL_ICONS, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 48, 100, 10
    CONTROL         "Show window previews", IDC_HOVER_PREVIEW, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 120, 48, 114, 10
    LTEXT           "Button Width:", IDC_STATIC, 14, 62, 50, 8
    CONTROL         "Auto (Length of label)", IDC_WIDTH_AUTO, "Button", BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP, 65, 61, 80, 10
    CONTROL         "Fixed", IDC_WIDTH_FIXED, "Button", BS_AUTORADIOBUTTON, 150, 61, 40, 10
    CONTROL         "Icons Only", IDC_WIDTH_ICONS, "Button", BS_AUTORADIOBUTTON, 195, 61, 45, 10
    
    GROUPBOX        "Taskbar Mode & Native Sync", IDC_STATIC, 7, 82, 238, 55
    CONTROL         "Independent", IDC_MODE_INDEPENDENT, "Button", BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP, 14, 95, 50, 10
    CONTROL         "Replace Native", IDC_MODE_REPLACE, "Button", BS_AUTORADIOBUTTON, 70, 95, 65, 10
    CONTROL         "Secondary Monitors Only", IDC_MODE_SECONDARY_ONLY, "Button", BS_AUTORADIOBUTTON, 140, 95, 95, 10
    CONTROL         "Use Native Windows Registry (1:1 Mirror)", IDC_NATIVE_REGISTRY_MODE, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 109, 220, 10
    CONTROL         "Native Win7 Tray", IDC_TRAY_NATIVE, "Button", BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP, 14, 123, 100, 10
    CONTROL         "Legacy Tray", IDC_TRAY_LEGACY, "Button", BS_AUTORADIOBUTTON, 120, 123, 100, 10

    GROUPBOX        "Multi-Monitor & Components", IDC_STATIC, 7, 142, 238, 65
    LTEXT           "Select Monitor:", IDC_STATIC, 14, 155, 50, 8
    COMBOBOX        IDC_MONITOR_LIST, 65, 153, 170, 50, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Enable:", IDC_STATIC, 14, 171, 40, 8
    LISTBOX         IDC_COMPONENTS_LIST, 55, 169, 180, 30, LBS_MULTIPLESEL | LBS_NOINTEGRALHEIGHT | WS_VSCROLL | WS_TABSTOP
END

IDD_STARTMENU_PROPS DIALOGEX 0, 0, 252, 218
STYLE DS_SETFONT | DS_FIXEDSYS | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Start Menu"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    GROUPBOX        "Start Menu Provider", IDC_STATIC, 7, 7, 238, 60
    CONTROL         "OpenShell Menu", IDC_START_OPENSHELL, "Button", BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP, 14, 20, 220, 10
    CONTROL         "Native Menu", IDC_START_NATIVE, "Button", BS_AUTORADIOBUTTON, 14, 34, 220, 10
    CONTROL         "Combination (Different Triggers)", IDC_START_COMBO, "Button", BS_AUTORADIOBUTTON, 14, 48, 220, 10
    
    LTEXT           "Trigger Behavior:", IDC_STATIC, 14, 75, 70, 8
    COMBOBOX        IDC_START_TRIGGER, 85, 73, 150, 50, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
END

IDD_DESKTOP_PROPS DIALOGEX 0, 0, 252, 218
STYLE DS_SETFONT | DS_FIXEDSYS | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Desktop"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    GROUPBOX        "Desktop icons", IDC_STATIC, 7, 7, 238, 100
END

IDD_TOOLBARS_PROPS DIALOGEX 0, 0, 252, 218
STYLE DS_SETFONT | DS_FIXEDSYS | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Toolbars"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    GROUPBOX        "Active Deskbands & Folders", IDC_STATIC, 7, 7, 238, 150
    LTEXT           "Toolbars are configured per-taskbar. Select toolbars below:", IDC_STATIC, 14, 20, 220, 10
    LISTBOX         IDC_TOOLBAR_LIST, 14, 34, 220, 100, LBS_MULTIPLESEL | LBS_STANDARD | WS_TABSTOP
    PUSHBUTTON      "New toolbar...", IDC_TOOLBAR_NEW, 164, 138, 70, 14
END

IDD_SECRET_EVERYTHING DIALOGEX 0, 0, 252, 218
STYLE DS_SETFONT | DS_FIXEDSYS | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "Everything Indexer"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    LTEXT           "Voidtools Everything IPC Backend Configuration.", IDC_STATIC, 7, 7, 238, 10
END

IDD_SECRET_DLLSCANNER DIALOGEX 0, 0, 252, 218
STYLE DS_SETFONT | DS_FIXEDSYS | WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "DLL Scanner"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    LTEXT           "Undocumented RunDLL32 Export Discovery Tool.", IDC_STATIC, 7, 7, 238, 10
END
