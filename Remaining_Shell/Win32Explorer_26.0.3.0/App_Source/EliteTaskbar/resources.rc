#include <windows.h>
#include "EliteTaskbar\resource.h"

IDI_MAIN_PROGRAM ICON "EliteTaskbar\\Resources\\MAIN_PROGRAM.ico"
IDI_PREFERENCES ICON "EliteTaskbar\\Resources\\PREFERENCES.ico"
IDB_START_ORB RCDATA "EliteTaskbar\\Resources\\StartOrb\\orb.png"
IDB_START_ORB_1ORB RCDATA "EliteTaskbar\\Resources\\StartOrb\\1orb.png"
IDB_START_ORB_AQUABOTTOM RCDATA "EliteTaskbar\\Resources\\StartOrb\\aqua bottom.png"
IDB_START_ORB_DUNES RCDATA "EliteTaskbar\\Resources\\StartOrb\\dunes.png"
IDB_START_ORB_INDIGO RCDATA "EliteTaskbar\\Resources\\StartOrb\\indigo.png"
IDB_START_ORB_SAPPHIRE RCDATA "EliteTaskbar\\Resources\\StartOrb\\sapphire.png"
IDB_START_ORB_URANUS RCDATA "EliteTaskbar\\Resources\\StartOrb\\uranus.png"
IDB_START_ORB_VIENNABOTTOM RCDATA "EliteTaskbar\\Resources\\StartOrb\\vienna bottom.png"

IDD_TASKBAR_PROPS DIALOGEX 0, 0, 252, 218
STYLE DS_SETFONT | DS_FIXEDSYS | WS_CHILD | WS_DISABLED | WS_CAPTION | DS_CONTROL
CAPTION "Taskbar"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    GROUPBOX        "Taskbar Mode", IDC_STATIC, 7, 7, 238, 45
    CONTROL         "Independent", IDC_MODE_INDEPENDENT, "Button", BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP, 14, 20, 60, 10
    CONTROL         "Replace", IDC_MODE_REPLACE, "Button", BS_AUTORADIOBUTTON, 80, 20, 50, 10
    CONTROL         "Secondary Only", IDC_MODE_SECONDARY_ONLY, "Button", BS_AUTORADIOBUTTON, 140, 20, 70, 10
    
    GROUPBOX        "Custom Icon Theme Folder", IDC_STATIC, 7, 58, 238, 77
    LTEXT           "Theme Path:", IDC_STATIC, 14, 73, 45, 8
    EDITTEXT        IDC_THEME_FOLDER_PATH, 65, 71, 120, 12, ES_AUTOHSCROLL | WS_TABSTOP
    PUSHBUTTON      "Browse...", IDC_THEME_FOLDER_BROWSE, 190, 70, 50, 14, WS_TABSTOP
    CONTROL         "Enable Dark Mode", IDC_ENABLE_DARK_MODE, "Button", BS_AUTOCHECKBOX | WS_DISABLED | WS_TABSTOP, 14, 95, 150, 10
END

IDD_NATIVE_PROPS DIALOGEX 0, 0, 252, 218
STYLE DS_SETFONT | DS_FIXEDSYS | WS_CHILD | WS_DISABLED | WS_CAPTION | DS_CONTROL
CAPTION "Native Settings"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    GROUPBOX        "Native Integration", IDC_STATIC, 7, 7, 238, 70
    CONTROL         "Write settings to native registry (Sync with explorer)", IDC_NATIVE_REGISTRY_MODE, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 20, 200, 10
    CONTROL         "Use fully native TaskBand (Requires theme support)", IDC_USE_NATIVE_TASKBAND, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 34, 200, 10
    CONTROL         "Native Win7 Tray", IDC_TRAY_NATIVE, "Button", BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP, 14, 50, 100, 10
    CONTROL         "Legacy Tray", IDC_TRAY_LEGACY, "Button", BS_AUTORADIOBUTTON, 120, 50, 100, 10
    
    GROUPBOX        "Shell Taskbar Overrides", IDC_STATIC, 7, 83, 238, 55
    CONTROL         "Lock the taskbar", IDC_LOCK_TASKBAR, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 96, 220, 10
    CONTROL         "Auto-hide the taskbar", IDC_AUTOHIDE_TASKBAR, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 110, 220, 10
    CONTROL         "Use small icons", IDC_SMALL_ICONS, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 124, 100, 10
END

IDD_MULTIMON_PROPS DIALOGEX 0, 0, 252, 218
STYLE DS_SETFONT | DS_FIXEDSYS | WS_CHILD | WS_DISABLED | WS_CAPTION | DS_CONTROL
CAPTION "Multi-Monitor"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    CONTROL         "", IDC_DYN_SCROLLAREA, "Static", SS_BLACKFRAME | NOT WS_VISIBLE, 0, 0, 252, 218
END

IDD_STARTMENU_PROPS DIALOGEX 0, 0, 252, 218
STYLE DS_SETFONT | DS_FIXEDSYS | WS_CHILD | WS_DISABLED | WS_CAPTION | DS_CONTROL
CAPTION "Start Menu"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    LTEXT           "Configure start menu per-monitor:", IDC_STATIC, 7, 7, 238, 8
    CONTROL         "", IDC_DYN_SCROLLAREA, "Static", SS_BLACKFRAME | NOT WS_VISIBLE, 7, 20, 238, 191
END

IDD_TOOLBARS_PROPS DIALOGEX 0, 0, 252, 218
STYLE DS_SETFONT | DS_FIXEDSYS | WS_CHILD | WS_DISABLED | WS_CAPTION | DS_CONTROL
CAPTION "Toolbars"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    GROUPBOX        "Active Deskbands & Folders", IDC_STATIC, 7, 7, 238, 150
    LTEXT           "Toolbars are configured per-taskbar. Select toolbars below:", IDC_STATIC, 14, 20, 220, 10
    LISTBOX         IDC_TOOLBAR_LIST, 14, 34, 220, 100, LBS_MULTIPLESEL | LBS_STANDARD | WS_TABSTOP
    PUSHBUTTON      "New toolbar...", IDC_TOOLBAR_NEW, 164, 138, 70, 14
END

IDD_SECRET_EVERYTHING DIALOGEX 0, 0, 252, 218
STYLE DS_SETFONT | DS_FIXEDSYS | WS_CHILD | WS_DISABLED | WS_CAPTION | DS_CONTROL
CAPTION "Everything Indexer"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    LTEXT           "Voidtools Everything IPC Backend Configuration.", IDC_STATIC, 7, 7, 238, 10
END

IDD_SECRET_DLLSCANNER DIALOGEX 0, 0, 252, 218
STYLE DS_SETFONT | DS_FIXEDSYS | WS_CHILD | WS_DISABLED | WS_CAPTION | DS_CONTROL
CAPTION "DLL Scanner"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    LTEXT           "Undocumented RunDLL32 Export Discovery Tool.", IDC_STATIC, 7, 7, 238, 10
END




